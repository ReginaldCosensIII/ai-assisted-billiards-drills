datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Drill {
  id          String   @id @default(uuid())
  title       String
  category    String
  difficulty  Int
  layout_data Json
  version     String
  status      String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("drills")
}
